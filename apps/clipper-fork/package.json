    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@authclip/shared-types": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
