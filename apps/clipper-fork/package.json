{
  "name": "@authclip/clipper-fork",
  "version": "0.3.0",
  "private": true,
  "description": "Browser extension — asset discovery, fetch, and capture packaging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:extension": "webpack --config webpack.config.mjs",
    "build:extension:prod": "NODE_ENV=production webpack --config webpack.config.mjs",
    "build:all": "tsc && webpack --config webpack.config.mjs",
    "dev:extension": "webpack --watch --config webpack.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@authclip/shared-types": "workspace:*",
    "@authclip/template-engine": "workspace:*",
    "dayjs": "^1.11.20",
    "defuddle": "^0.16.0",
    "dompurify": "^3.4.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/dompurify": "^3.2.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "esbuild": "^0.28.0",
    "jsdom": "^26.0.0",
    "mini-css-extract-plugin": "^2.10.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  }
}
