{
  "name": "@authclip/clipper-fork",
  "version": "0.1.0",
  "private": true,
  "description": "Browser extension — asset discovery, fetch, and capture packaging",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
