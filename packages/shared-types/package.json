{
  "name": "@authclip/shared-types",
  "version": "0.1.0",
  "description": "Shared types, schemas, and utilities for AuthClip",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
